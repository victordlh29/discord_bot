# Base de datos
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stanplaya?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Discord Bot
DISCORD_BOT_TOKEN="tu_token_del_bot"
DISCORD_CLIENT_ID="tu_client_id"
DISCORD_GUILD_ID="tu_guild_id"

# Dashboard
DISCORD_CLIENT_SECRET="tu_client_secret"
NEXTAUTH_SECRET="tu_nextauth_secret"
NEXTAUTH_URL="http://localhost:3000"

# JWT
JWT_SECRET="tu_jwt_secret"
JWT_EXPIRES_IN="7d"

# Super Admin (acceso con usuario/contraseña)
SUPERADMIN_USER="admin"
SUPERADMIN_PASSWORD="tu_contraseña_segura"

# API
API_PORT=4000
DASHBOARD_URL="http://localhost:3000"
