# ─────────────────────────────────────────────
#  BACKEND - Variables de Entorno
#  Copia este archivo como .env y completa los valores
# ─────────────────────────────────────────────

# ── Discord ──
DISCORD_BOT_TOKEN=tu_token_del_bot_aqui
DISCORD_CLIENT_ID=tu_client_id_aqui
DISCORD_CLIENT_SECRET=tu_client_secret_aqui
DISCORD_GUILD_ID=id_del_servidor_principal

# ── Base de Datos (PostgreSQL) ──
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stanplaya"

# ── Autenticacion JWT ──
# Genera un secreto con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=genera_un_secreto_64_bytes_hex_aqui
JWT_EXPIRES_IN=7d

# ── API Key (debe coincidir entre backend y dashboard) ──
API_KEY=comparte_esta_key_con_el_dashboard

# ── Admin Login (para acceso sin Discord) ──
# http://localhost:3000/admin/login
SUPERADMIN_USER=admin
# ⚠️ IMPORTANTE: Si usás un hash de bcrypt (generado con scripts/hash-password.ts):
#    El hash contiene caracteres $ que NO deben ir entre comillas dobles.
#    ✅ SUPERADMIN_PASSWORD='$2b$12$...'  (comillas simples OK)
#    ✅ SUPERADMIN_PASSWORD=$2b$12$...     (sin comillas OK)
#    ❌ SUPERADMIN_PASSWORD="$2b$12$..."  (comillas dobles: los $ se rompen)
SUPERADMIN_PASSWORD=genera_una_contraseña_segura_aqui

# ── URLs ──
DASHBOARD_URL=http://localhost:3000
API_PORT=4000

# ── Redis (opcional) ──
REDIS_URL=redis://localhost:6379

# ── Swagger (deshabilitado por defecto en producción) ──
# Cambia a "true" para habilitar la documentación interactiva en /api-docs
SWAGGER_ENABLED=true

# ── Protección contra Fuerza Bruta (Admin Login) ──
# Número máximo de intentos fallidos antes de bloquear la IP
ADMIN_LOGIN_MAX_ATTEMPTS=5
# Duración del bloqueo en minutos después de alcanzar el límite
ADMIN_LOGIN_BLOCK_MINUTES=60

# ── Entorno ──
NODE_ENV=development
