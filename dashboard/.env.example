# ─────────────────────────────────────────────
#  DASHBOARD - Variables de Entorno
#  Copia este archivo como .env y completa los valores
# ─────────────────────────────────────────────

# ── Discord OAuth ──
NEXT_PUBLIC_DISCORD_CLIENT_ID=tu_client_id_aqui
DISCORD_CLIENT_SECRET=tu_client_secret_aqui
NEXT_PUBLIC_DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Backend API ──
BACKEND_URL=http://localhost:4000/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# URL del backend para rewrites de Next.js (sin NEXT_PUBLIC_)
API_URL=http://localhost:4000
# URL base del backend para SSE (conexiones en vivo, sin /api suffix)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ── API Key (debe coincidir con backend) ──
API_KEY=comparte_esta_key_con_el_backend
